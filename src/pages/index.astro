---
import Layout from '@/layouts/Layout.astro';
import { HeroSection } from '@/components/home/HeroSection';
import { PillarsSection } from '@/components/home/PillarsSection';
import { FeaturedProducts } from '@/components/home/FeaturedProducts';
import { WhyTDHSection } from '@/components/home/WhyTDHSection';
import { CTABlock } from '@/components/shared/CTABlock';
import { organizationStructuredData, websiteStructuredData } from '@/lib/seo';

const structuredData = [organizationStructuredData, websiteStructuredData];
---

<Layout
  title="TDH — ساخت و تجاری‌سازی نرم‌افزارها و خدمات کاربردی"
  description="تکین داده هوشمند نرم‌افزار و خدمات کاربردی می‌سازد؛ از دستیار هوشمند فارسی و مانیتورینگ سرور با AI تا اعلان‌رسانی یکپارچه برای Agent های هوشمند."
  keywords="TDH, تکین داده هوشمند, دستیار هوشمند فارسی, مانیتورینگ سرور, ServerGuard, Watch Tower, توسعه نرم‌افزار سفارشی, هوش مصنوعی فارسی"
  canonical="/"
  structuredData={structuredData}
>
  <main>
    <HeroSection />
    <PillarsSection client:load />
    <FeaturedProducts />
    <WhyTDHSection />
    <CTABlock />
  </main>
</Layout>
