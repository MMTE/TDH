---
import Layout from '@/layouts/Layout.astro';
import { AboutContent } from '@/components/pages/AboutContent';
import { createBreadcrumbStructuredData, createArticleStructuredData } from '@/lib/seo';

const breadcrumbData = createBreadcrumbStructuredData([
  { name: 'خانه', url: '/' },
  { name: 'درباره ما', url: '/about' },
]);

const articleData = createArticleStructuredData(
  'درباره تکین داده هوشمند (TDH)',
  'تکین داده هوشمند - شرکت با مسئولیت محدود. پلتفرم‌های SaaS برای حل چالش‌های واقعی کسب‌وکارها.',
  new Date().toISOString()
);

const structuredData = [breadcrumbData, articleData];
---

<Layout
  title="درباره TDH | از سال ۱۳۹۵ داریم ابزار می‌سازیم که واقعاً کار می‌کنه"
  description="تکین داده هوشمند (TDH) — ۹ سال تجربه تو نرم‌افزار سازمانی. سه پلتفرم: مجموعه کسب‌وکار، پلتفرم داده و گردش‌کار."
  keywords="تکین داده هوشمند, TDH, نرم‌افزار سازمانی, SaaS, نرم‌افزار حسابداری, ERP, اتوماسیون فرآیند"
  canonical="/about"
  ogType="article"
  structuredData={structuredData}
>
  <AboutContent />
</Layout>
