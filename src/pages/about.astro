---
import Layout from '@/layouts/Layout.astro';
import { AboutContent } from '@/components/pages/AboutContent';
import { createBreadcrumbStructuredData, createArticleStructuredData } from '@/lib/seo';

const breadcrumbData = createBreadcrumbStructuredData([
  { name: 'خانه', url: '/' },
  { name: 'درباره ما', url: '/about' },
]);

const articleData = createArticleStructuredData(
  'درباره تکین داده هوشمند (TDH)',
  'تکین داده هوشمند - شرکت با مسئولیت محدود. پلتفرم‌های SaaS برای حل چالش‌های واقعی کسب‌وکارها.',
  new Date().toISOString()
);

const structuredData = [breadcrumbData, articleData];
---

<Layout
  title="درباره تکین داده هوشمند | طراحی و توسعه نرم‌افزارهای حرفه‌ای"
  description="شرکت تکین داده هوشمند (TDH) طراح و توسعه‌دهنده محصولات نرم‌افزاری شامل سیستم CRM جامع، راه‌حل‌های فروشگاهی و ابزارهای تحلیل اطلاعات برای کسب‌وکارها."
  keywords="تکین داده هوشمند, TDH, شرکت نرم‌افزاری, توسعه نرم‌افزار, CRM فارسی, راه‌حل فروشگاهی"
  canonical="/about"
  ogType="article"
  structuredData={structuredData}
>
  <AboutContent />
</Layout>
