---
import Layout from '@/layouts/Layout.astro';
---
<Layout title="صفحه پیدا نشد - 404" description="صفحه مورد نظر شما یافت نشد." noindex={true}>
  <main class="min-h-screen flex items-center justify-center">
    <div class="container px-6 text-center">
      <div class="max-w-lg mx-auto">
        <div class="mono text-sm text-fg-subtle mb-8" style="letter-spacing: 0.15em">REF · ERROR</div>
        <div class="text-[120px] font-bold leading-none mb-8" style="color: var(--color-accent); font-family: var(--font-mono)">۴۰۴</div>
        <h1 class="text-3xl font-bold text-fg mb-4">صفحه پیدا نشد</h1>
        <p class="mono text-sm text-fg-subtle mb-8">مسیر درخواستی وجود ندارد</p>
        <a href="/" class="inline-block px-8 py-4 text-bg font-semibold" style="background: var(--color-accent)">بازگشت به خانه ←</a>
      </div>
    </div>
  </main>
</Layout>
