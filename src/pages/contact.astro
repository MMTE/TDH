---
import Layout from '@/layouts/Layout.astro';
import { ContactContent } from '@/components/pages/ContactContent';
import { createBreadcrumbStructuredData } from '@/lib/seo';

const breadcrumbData = createBreadcrumbStructuredData([
  { name: 'خانه', url: '/' },
  { name: 'تماس با ما', url: '/contact' },
]);

const contactStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'تماس با TDH',
  description: 'صفحه تماس با تیم TDH برای شروع گفت‌وگو، معرفی محصول و مشاوره فنی',
  mainEntity: {
    '@type': 'Organization',
    name: 'TDH',
    email: 'info@tdh.ir',
    telephone: '+98-21-28428084',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'تهران',
      addressCountry: 'IR',
    },
  },
};

const structuredData = [breadcrumbData, contactStructuredData];
---

<Layout
  title="تماس با تکین داده هوشمند | مشاوره، سفارش نرم‌افزار و درخواست دمو"
  description="برای مشاوره فنی، سفارش نرم‌افزار سفارشی یا درخواست دمو محصولات با تکین داده هوشمند تماس بگیرید. ظرف ۲۴ ساعت پاسخ می‌دهیم."
  keywords="تماس با TDH, مشاوره نرم‌افزار, درخواست دمو CRM, سفارش نرم‌افزار, توسعه سفارشی, تکین داده هوشمند"
  canonical="/contact"
  structuredData={structuredData}
>
  <ContactContent client:load />
</Layout>
