---
import Layout from '@/layouts/Layout.astro';
import { ContactContent } from '@/components/pages/ContactContent';
import { createBreadcrumbStructuredData } from '@/lib/seo';

const breadcrumbData = createBreadcrumbStructuredData([
  { name: 'خانه', url: '/' },
  { name: 'تماس با ما', url: '/contact' },
]);

const contactStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'تماس با TDH',
  description: 'صفحه تماس با تیم TDH برای درخواست دمو و مشاوره',
  mainEntity: {
    '@type': 'Organization',
    name: 'TDH',
    email: 'info@tdh.ir',
    telephone: '+98-21-XXXX-XXXX',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'تهران',
      addressCountry: 'IR',
    },
  },
};

const structuredData = [breadcrumbData, contactStructuredData];
---

<Layout
  title="تماس با TDH - درخواست دمو رایگان | مشاوره و پشتیبانی"
  description="آماده‌اید ببینید TDH چه کاری می‌تواند برای کسب‌وکار شما انجام دهد؟ یک دمو رایگان رزرو کنید. تیم ما ظرف ۲۴ ساعت پاسخ می‌دهد. مشاوره رایگان، بدون تعهد. تهران، ایران."
  keywords="تماس با TDH, درخواست دمو, مشاوره رایگان, پشتیبانی TDH, فروش TDH, تماس با شرکت نرم‌افزاری, دمو رایگان ERP, مشاوره نرم‌افزار سازمانی"
  canonical="/contact"
  structuredData={structuredData}
>
  <ContactContent client:load />
</Layout>
