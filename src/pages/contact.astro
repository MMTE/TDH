---
import Layout from '@/layouts/Layout.astro';
import { ContactContent } from '@/components/pages/ContactContent';
import { createBreadcrumbStructuredData } from '@/lib/seo';

const breadcrumbData = createBreadcrumbStructuredData([
  { name: 'خانه', url: '/' },
  { name: 'تماس با ما', url: '/contact' },
]);

const contactStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'تماس با TDH',
  description: 'صفحه تماس با تیم TDH برای شروع گفت‌وگو، معرفی محصول و مشاوره فنی',
  mainEntity: {
    '@type': 'Organization',
    name: 'TDH',
    email: 'info@tdh.ir',
    telephone: '+98-21-28428084',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'تهران',
      addressCountry: 'IR',
    },
  },
};

const structuredData = [breadcrumbData, contactStructuredData];
---

<Layout
  title="تماس با TDH | شروع گفت‌وگو درباره محصول، زیرساخت یا نرم‌افزار سفارشی"
  description="برای معرفی محصول، مشاوره فنی یا شروع یک پروژه نرم‌افزاری با TDH تماس بگیرید. مسأله را می‌شنویم و ظرف ۲۴ ساعت پاسخ می‌دهیم."
  keywords="تماس با TDH, مشاوره فنی, توسعه نرم‌افزار سفارشی, معرفی محصول, پشتیبانی TDH, ServerGuard, Watch Tower, دستیار هوشمند فارسی"
  canonical="/contact"
  structuredData={structuredData}
>
  <ContactContent client:load />
</Layout>
