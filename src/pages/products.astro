---
import Layout from '@/layouts/Layout.astro';
import { ProductsContent } from '@/components/pages/ProductsContent';
import { createBreadcrumbStructuredData, createProductStructuredData } from '@/lib/seo';
import { products } from '@/lib/products';

const breadcrumbData = createBreadcrumbStructuredData([
  { name: 'خانه', url: '/' },
  { name: 'محصولات', url: '/products' },
]);

const productsStructuredData = products.map((product) =>
  createProductStructuredData(product.name, product.shortDescription, product.image, product.pricing)
);

const structuredData = [breadcrumbData, ...productsStructuredData];
---

<Layout
  title="محصولات TDH — دستیار هوشمند فارسی، ServerGuard و Watch Tower"
  description="سه ابزار کاربردی TDH: دستیار هوشمند فارسی، مانیتورینگ سرور با AI، و هاب اعلان‌رسانی یکپارچه برای اپلیکیشن‌ها و Agent های هوشمند."
  keywords="محصولات TDH, دستیار هوشمند فارسی, مشابه چت‌جی‌پی‌تی, ServerGuard, Watch Tower, مانیتورینگ سرور, اعلان‌رسانی, AI Agent, هوش مصنوعی فارسی"
  canonical="/products"
  structuredData={structuredData}
>
  <ProductsContent />
</Layout>
