---
import Layout from '@/layouts/Layout.astro';
import { ProductsContent } from '@/components/pages/ProductsContent';
import { createBreadcrumbStructuredData, createProductStructuredData } from '@/lib/seo';
import { products } from '@/lib/products';

const breadcrumbData = createBreadcrumbStructuredData([
  { name: 'خانه', url: '/' },
  { name: 'محصولات', url: '/products' },
]);

const productsStructuredData = products.map((product) =>
  createProductStructuredData(product.name, product.shortDescription, product.image, product.pricing)
);

const structuredData = [breadcrumbData, ...productsStructuredData];
---

<Layout
  title="محصولات تکین داده هوشمند | CRM فارسی، فروشگاه‌ساز و تحلیل اطلاعات"
  description="محصولات نرم‌افزاری تکین داده هوشمند: CRM360 سیستم جامع مدیریت مشتریان، Factorino مدیریت فروشگاه آنلاین و Topinar جستجو و تحلیل اطلاعات سازمانی."
  keywords="محصولات TDH, CRM فارسی, CRM360, مدیریت فروشگاه آنلاین, Factorino, تحلیل اطلاعات, Topinar, نرم‌افزار سازمانی, تکین داده هوشمند"
  canonical="/products"
  structuredData={structuredData}
>
  <ProductsContent />
</Layout>
