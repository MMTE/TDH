---
import Layout from '@/layouts/Layout.astro';
import { FAQContent } from '@/components/pages/FAQContent';
import { createBreadcrumbStructuredData } from '@/lib/seo';

const breadcrumbData = createBreadcrumbStructuredData([
  { name: 'خانه', url: '/' },
  { name: 'پرسش‌های متداول', url: '/faq' },
]);

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'TDH چیست و چه کاری انجام می‌دهد؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'تکین داده هوشمند نرم‌افزار و خدمات کاربردی می‌سازد؛ از دستیار هوشمند فارسی و مانیتورینگ سرور با AI تا اعلان‌رسانی یکپارچه و توسعه نرم‌افزار سفارشی.',
      },
    },
    {
      '@type': 'Question',
      name: 'نحوه قیمت‌گذاری محصولات TDH چگونه است؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'قیمت محصولات آماده بر اساس نوع محصول و پلن مشخص می‌شود. خدمات سفارشی بر اساس دامنه پروژه، نیاز فنی و زمان پیاده‌سازی قیمت‌گذاری می‌شوند.',
      },
    },
    {
      '@type': 'Question',
      name: 'زمان پیاده‌سازی محصولات TDH چقدر است؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'زمان پیاده‌سازی به نوع محصول یا پروژه بستگی دارد و پس از جلسه مسأله‌شناسی، زمان‌بندی شفاف ارائه می‌شود.',
      },
    },
  ],
};

const structuredData = [breadcrumbData, faqStructuredData];
---

<Layout
  title="پرسش‌های متداول TDH | محصولات، خدمات، قیمت‌گذاری و پشتیبانی"
  description="پاسخ به پرسش‌های متداول درباره محصولات و خدمات TDH؛ دستیار هوشمند فارسی، ServerGuard، Watch Tower، توسعه سفارشی، قیمت‌گذاری، پشتیبانی و امنیت."
  keywords="پرسش‌های متداول TDH, FAQ TDH, دستیار هوشمند فارسی, ServerGuard, Watch Tower, قیمت نرم‌افزار, پشتیبانی TDH, امنیت داده"
  canonical="/faq"
  structuredData={structuredData}
>
  <FAQContent client:load />
</Layout>
