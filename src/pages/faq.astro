---
import Layout from '@/layouts/Layout.astro';
import { FAQContent } from '@/components/pages/FAQContent';
import { createBreadcrumbStructuredData } from '@/lib/seo';

const breadcrumbData = createBreadcrumbStructuredData([
  { name: 'خانه', url: '/' },
  { name: 'پرسش‌های متداول', url: '/faq' },
]);

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'تکین داده هوشمند چیست و چه کاری انجام می‌دهد؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'تکین داده هوشمند نرم‌افزار و خدمات کاربردی می‌سازد؛ از سیستم CRM جامع و راه‌حل‌های فروشگاهی تا ابزارهای جستجو و تحلیل اطلاعات و توسعه نرم‌افزار سفارشی.',
      },
    },
    {
      '@type': 'Question',
      name: 'نحوه قیمت‌گذاری محصولات TDH چگونه است؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'قیمت محصولات آماده بر اساس نوع محصول و پلن مشخص می‌شود. خدمات سفارشی بر اساس دامنه پروژه، نیاز فنی و زمان پیاده‌سازی قیمت‌گذاری می‌شوند.',
      },
    },
    {
      '@type': 'Question',
      name: 'زمان پیاده‌سازی محصولات TDH چقدر است؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'زمان پیاده‌سازی به نوع محصول یا پروژه بستگی دارد و پس از جلسه مسأله‌شناسی، زمان‌بندی شفاف ارائه می‌شود.',
      },
    },
  ],
};

const structuredData = [breadcrumbData, faqStructuredData];
---

<Layout
  title="پرسش‌های متداول تکین داده هوشمند | محصولات، قیمت و پشتیبانی"
  description="پاسخ به پرسش‌های متداول درباره محصولات و خدمات تکین داده هوشمند؛ CRM فارسی، مدیریت فروشگاهی، تحلیل اطلاعات، قیمت‌گذاری، پشتیبانی و امنیت داده."
  keywords="پرسش‌های متداول TDH, FAQ, CRM فارسی, قیمت CRM, پشتیبانی نرم‌افزار, امنیت داده, تکین داده هوشمند"
  canonical="/faq"
  structuredData={structuredData}
>
  <FAQContent client:load />
</Layout>
